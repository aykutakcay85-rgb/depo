# Chef Aykut Backend - Environment Variables Example
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin.
# Production ortamında (Render vb.) bu değerleri "Environment" sekmesine ekleyin.

PORT=3000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
BUCKET_NAME=foodi
APP_API_KEY=your_super_secret_api_key

# CORS için izin verilen origin (Virgülle ayırarak birden fazla eklenebilir)
ALLOWED_ORIGINS=https://your-app.onrender.com,http://localhost:3000
